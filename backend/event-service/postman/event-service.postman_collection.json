    {
      "name": "3. Events",
      "item": [
        {
          "name": "Create Event (Organizer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.event && json.data.event._id) {",
                  "  pm.collectionVariables.set('eventId', json.data.event._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{organizerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Campus Hack Night 2026\",\n  \"description\": \"Overnight coding sprint for campus innovators.\",\n  \"shortDescription\": \"12-hour coding challenge\",\n  \"category\": \"Hackathon\",\n  \"tags\": [\"coding\", \"innovation\", \"team\"],\n  \"venue\": {\n    \"name\": \"Main Auditorium\",\n    \"address\": \"Block A, Campus\",\n    \"isOnline\": false,\n    \"meetingLink\": \"\"\n  },\n  \"startDate\": \"2026-05-20T09:00:00.000Z\",\n  \"endDate\": \"2026-05-20T21:00:00.000Z\",\n  \"registrationDeadline\": \"2026-05-18T23:59:59.000Z\",\n  \"capacity\": {\n    \"total\": 200\n  },\n  \"status\": \"published\",\n  \"isPublic\": true,\n  \"isFeatured\": true,\n  \"price\": 0\n}"
            },
            "url": {
              "raw": "{{eventBaseUrl}}/api/events",
              "host": ["{{eventBaseUrl}}"],
              "path": ["api", "events"]
            }
          },
          "response": []
        },
